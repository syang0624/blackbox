# BlackBox — backend environment (Approach A: graph-first, thin runtime)
# Copy to .env and fill in real values. Do NOT commit .env (it is gitignored).
# The service boots even with placeholders — Butterbase falls back to an
# in-memory adapter so nothing is blocked while credentials land.

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
APP_ENV=development
PORT=4000
# Frontend origin(s) allowed to hit the API / SSE stream (Steven's app).
# Comma-separated allowlist; the deployed Edge SSR origin must be included.
# Use "*" to reflect any origin (dev only).
CORS_ORIGIN=http://localhost:3000,https://blackbox.butterbase.dev

# ------------------------------------------------------------
# Neo4j — the email entity graph (REQUIRED, load-bearing)
# Free instance: https://console.neo4j.io  (AuraDB Free)
# ------------------------------------------------------------
NEO4J_URI=neo4j+s://YOUR_INSTANCE.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# ------------------------------------------------------------
# Butterbase — runtime: database, storage, RAG, AI gateway
# One bb_sk_ key (with `*` scope) authenticates ALL of these.
# api_url + app_id come from `init_app` / the Butterbase dashboard.
# ------------------------------------------------------------
BUTTERBASE_API_URL=https://api.butterbase.ai
BUTTERBASE_APP_ID=app_your_app_id
BUTTERBASE_API_KEY=bb_sk_your_key
# Optional: only set these if you mint separate narrowly-scoped keys.
# Otherwise BUTTERBASE_API_KEY is used for the AI gateway too.
BUTTERBASE_SERVICE_ROLE_KEY=
BUTTERBASE_AI_API_KEY=

# Butterbase RAG — collection holding the United IVR map + rebooking policy
BUTTERBASE_RAG_COLLECTION=support-knowledge

# Butterbase OpenAI-compatible LLM gateway.
# RocketRide's llm_openai_api node uses these as:
# Authorization: Bearer ${BUTTERBASE_API_KEY}
# base_url: ${BUTTERBASE_BASE_URL}
# model: ${BUTTERBASE_MODEL}
BUTTERBASE_BASE_URL=https://api.butterbase.ai/v1
BUTTERBASE_MODEL=anthropic/claude-sonnet-4.5

# ------------------------------------------------------------
# RocketRide — managed AI extraction pipeline (MANDATORY sponsor service)
# Runs the email -> structured-entities extraction as a .pipe pipeline
# (chat source -> llm node -> response_answers), consumed via the `rocketride`
# TypeScript SDK. This is what feeds the Neo4j graph.
#
# ROCKETRIDE_URI and ROCKETRIDE_APIKEY are auto-synced into .env by the
# RocketRide VSCode extension from its settings — do NOT hand-edit them.
# ------------------------------------------------------------
ROCKETRIDE_URI=https://api.rocketride.ai
ROCKETRIDE_APIKEY=your_rocketride_api_key
# Pipeline ${ROCKETRIDE_*} substitution (required by the VS Code extension on validate/run).
# Mirror BUTTERBASE_* / NEO4J_* here — model + base_url are literals in extraction.pipe.
ROCKETRIDE_BUTTERBASE_API_KEY=bb_sk_your_key
ROCKETRIDE_NEO4J_URI=neo4j+s://YOUR_INSTANCE.databases.neo4j.io
ROCKETRIDE_NEO4J_USER=neo4j
ROCKETRIDE_NEO4J_PASSWORD=your_neo4j_password
ROCKETRIDE_NEO4J_DATABASE=neo4j

# ------------------------------------------------------------
# Demo assets (recorded call — see PRD §12)
# Storage is app-scoped: upload the recorded audio, then paste its objectId here.
# The API presigns this objectId and hands the URL to the frontend.
# ------------------------------------------------------------
RECORDED_CALL_AUDIO_OBJECT_ID=

# ------------------------------------------------------------
# Feature flags
# ------------------------------------------------------------
# Run the recorded-audio demo timeline (always true for the hackathon).
ENABLE_RECORDED_CALL_DEMO=true
# Real outbound dialing — out of scope for the MVP.
ENABLE_REAL_PHONE_CALL=false
