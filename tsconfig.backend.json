{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "outDir": "dist"
  },
  "include": [
    "src/ai",
    "src/briefing",
    "src/config.ts",
    "src/db",
    "src/demo",
    "src/extraction",
    "src/graph",
    "src/logger.ts",
    "src/orchestrator",
    "src/rag",
    "src/routes",
    "src/seed",
    "src/server.ts",
    "src/sse",
    "src/types.ts",
    "tests"
  ]
}
