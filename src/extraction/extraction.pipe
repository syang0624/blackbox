{
  "components": [
    {
      "id": "chat_1",
      "provider": "chat",
      "name": "Email Intake",
      "config": {
        "hideForm": true,
        "mode": "Source",
        "parameters": {},
        "type": "chat"
      },
      "ui": {
        "position": { "x": 20, "y": 200 },
        "measured": { "width": 150, "height": 66 },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "prompt_1",
      "provider": "prompt",
      "name": "Travel Context",
      "config": {
        "instructions": [
          "You are BlackBox's travel-email entity extractor for airline support automation.",
          "Extract structured entities from forwarded booking confirmations, receipts, loyalty notices, and baggage claims.",
          "Return JSON with optional keys: person, booking, flight, loyalty, payment, baggage, airports.",
          "Omit unknown fields. For payment include brand and last4 only — never full card numbers.",
          "Normalize flight routes as ORIGIN -> DESTINATION (e.g. ICN -> SFO). Use IATA airport codes when present."
        ]
      },
      "input": [{ "lane": "questions", "from": "chat_1" }],
      "ui": {
        "position": { "x": 240, "y": 200 },
        "measured": { "width": 150, "height": 66 },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "guardrails_in_1",
      "provider": "guardrails",
      "name": "Input Guardrails",
      "config": {
        "profile": "basic",
        "basic": { "policy_mode": "warn" }
      },
      "input": [{ "lane": "questions", "from": "prompt_1" }],
      "ui": {
        "position": { "x": 460, "y": 200 },
        "measured": { "width": 150, "height": 66 },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "agent_1",
      "provider": "agent_rocketride",
      "name": "Wave Agent",
      "config": {
        "agent_description": "Extracts travel entities from raw email text and returns structured JSON for Neo4j graph ingestion.",
        "instructions": [
          "Parse the email headers and body. Extract person, booking (PNR + airline), flight (number, date, route, status), loyalty, payment (brand + last4), and baggage when present.",
          "Use keyed memory to track partial extractions across waves. Prefer direct parsing over tool calls unless enrichment is clearly needed.",
          "Final response MUST be a single JSON object matching the schema — no markdown fences or commentary."
        ],
        "max_waves": 5,
        "parameters": {}
      },
      "input": [{ "lane": "questions", "from": "guardrails_in_1" }],
      "ui": {
        "position": { "x": 680, "y": 200 },
        "measured": { "width": 150, "height": 86 },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "guardrails_out_1",
      "provider": "guardrails",
      "name": "Output Guardrails",
      "config": {
        "profile": "strict",
        "strict": {
          "policy_mode": "warn",
          "max_tokens_estimate": 0,
          "expected_format": "json"
        }
      },
      "input": [{ "lane": "answers", "from": "agent_1" }],
      "ui": {
        "position": { "x": 900, "y": 200 },
        "measured": { "width": 150, "height": 66 },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "response_1",
      "provider": "response_answers",
      "name": "Return Entities",
      "config": { "laneName": "answers" },
      "input": [{ "lane": "answers", "from": "guardrails_out_1" }],
      "ui": {
        "position": { "x": 1120, "y": 200 },
        "measured": { "width": 150, "height": 66 },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "llm_1",
      "provider": "llm_openai_api",
      "name": "Butterbase LLM",
      "config": {
        "profile": "custom",
        "custom": {
          "apikey": "${ROCKETRIDE_BUTTERBASE_API_KEY}",
          "base_url": "https://api.butterbase.ai/v1",
          "model": "anthropic/claude-sonnet-4.5",
          "modelTotalTokens": 200000
        }
      },
      "control": [
        { "classType": "llm", "from": "agent_1" },
        { "classType": "llm", "from": "db_neo4j_1" }
      ],
      "ui": {
        "position": { "x": 350, "y": 360 },
        "measured": { "width": 150, "height": 66 },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "memory_1",
      "provider": "memory_internal",
      "name": "Wave Memory",
      "config": { "type": "memory_internal" },
      "control": [{ "classType": "memory", "from": "agent_1" }],
      "ui": {
        "position": { "x": 570, "y": 360 },
        "measured": { "width": 150, "height": 66 },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "tool_butterbase_1",
      "provider": "tool_butterbase",
      "name": "Butterbase MCP",
      "config": {
        "type": "tool_butterbase",
        "bearer": "${ROCKETRIDE_BUTTERBASE_API_KEY}",
        "endpoint": "https://api.butterbase.ai/mcp",
        "serverName": "butterbase"
      },
      "control": [{ "classType": "tool", "from": "agent_1" }],
      "ui": {
        "position": { "x": 790, "y": 360 },
        "measured": { "width": 150, "height": 40 },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "db_neo4j_1",
      "provider": "db_neo4j",
      "name": "Neo4j Graph",
      "config": {
        "profile": "default",
        "default": {
          "db_description": "BlackBox travel entity graph: Person, Email, Booking, Flight, Airline, LoyaltyAccount, PaymentMethod, Airport nodes linked by CONFIRMED, FLEW, HAS_LOYALTY, PAID_WITH, and related edges.",
          "uri": "${ROCKETRIDE_NEO4J_URI}",
          "auth_method": "userpass",
          "user": "${ROCKETRIDE_NEO4J_USER}",
          "password": "${ROCKETRIDE_NEO4J_PASSWORD}",
          "database": "${ROCKETRIDE_NEO4J_DATABASE}",
          "max_attempts": 5,
          "allow_execute": false
        }
      },
      "control": [{ "classType": "tool", "from": "agent_1" }],
      "ui": {
        "position": { "x": 1010, "y": 360 },
        "measured": { "width": 150, "height": 66 },
        "nodeType": "default",
        "formDataValid": true
      }
    }
  ],
  "project_id": "7EC2F8BC-6297-49F2-B311-04DE536AB418",
  "source": "chat_1",
  "viewport": { "x": 0, "y": 0, "zoom": 0.85 },
  "version": 1,
  "isLocked": false,
  "snapToGrid": true,
  "snapGridSize": [10, 10],
  "docRevision": 12
}
