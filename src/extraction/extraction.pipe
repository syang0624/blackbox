{
  "components": [
    {
      "id": "chat_1",
      "provider": "chat",
      "config": {
        "hideForm": true,
        "mode": "Source",
        "parameters": {},
        "type": "chat"
      }
    },
    {
      "id": "llm_1",
      "provider": "llm_openai_api",
      "config": {
        "profile": "custom",
        "custom": {
          "apikey": "${ROCKETRIDE_BUTTERBASE_API_KEY}",
          "base_url": "${ROCKETRIDE_BUTTERBASE_BASE_URL}",
